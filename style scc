body {
  font-family: 'Poppins', sans-serif;
  margin: 0;
  background-color: #fff8f0;
  color: #222;
}

header {
  background-color: #e63946;
  color: white;
  text-align: center;
  padding: 1.5rem 0;
}

nav ul {
  list-style: none;
  padding: 0;
  display: flex;
  justify-content: center;
  gap: 1.5rem;
}

nav a {
  color: white;
  text-decoration: none;
  font-weight: bold;
}

.trending, .hot-gossip, .community {
  padding: 2rem;
  text-align: center;
}

.carousel, .grid {
  display: flex;
  justify-content: center;
  gap: 1rem;
  flex-wrap: wrap;
}

.card, .story {
  background-color: #f1faee;
  border: 1px solid #ccc;
  padding: 1rem;
  width: 200px;
  border-radius: 8px;
}

button {
  background-color: #e63946;
  color: white;
  border: none;
  padding: 0.7rem 1.2rem;
  border-radius: 5px;
  cursor: pointer;
}

footer {
  background-color: #222;
  color: white;
  text-align: center;
  padding: 1rem;
}
