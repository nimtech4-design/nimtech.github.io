body {
  font-family: 'Poppins', sans-serif;
  margin: 0;
  background-color: #fff8f0;
  color: #222;
}

header {
  background-color: #e63946;
  color: white;
  text-align: center;
  padding: 1.5rem 0;
}

nav ul {
  list-style: none;
  padding: 0;
  display: flex;
  justify-content: center;
  gap: 1.5rem;
}

nav a {
  color: white;
  text-decoration: none;
  font-weight: bold;
}

.trending, .hot-gossip, .community {
  padding: 2rem;
  text-align: center;
}


  .carousel {
  display: flex;
  overflow: hidden;
  width: 100%;
  max-width: 600px;
  margin: auto;
}

.story {
  flex: 0 0 100%;
  text-align: center;
  font-weight: bold;
  font-size: 1.2rem;
  background-color: #f1faee;
  padding: 2rem;
  border-radius: 8px;
}

#submittedGossip {
  margin-top: 1rem;
  background-color: #f1faee;
  padding: 1rem;
  border-radius: 5px;
}
